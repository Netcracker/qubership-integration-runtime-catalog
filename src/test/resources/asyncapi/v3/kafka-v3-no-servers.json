{
  "asyncapi": "3.0.0",
  "info": {
    "title": "Kafka No Servers API",
    "version": "1.0.0",
    "x-protocol": "kafka"
  },
  "channels": {
    "eventChannel": {
      "address": "events/all",
      "messages": {
        "GenericEvent": {
          "payload": {
            "type": "object",
            "properties": {
              "eventId": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "operations": {
    "publishEvent": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/eventChannel"
      },
      "summary": "Publish event"
    }
  }
}
